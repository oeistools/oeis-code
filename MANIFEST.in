# --- Core metadata ---
include README.md
include LICENSE

# --- Build / config ---
include pyproject.toml
include setup.cfg

# --- Package data (only needed if not handled by setuptools config) ---
recursive-include oeis_code *.py
recursive-include oeis_code *.pyi
recursive-include oeis_code py.typed

# --- Tests (optional: include for sdist, not needed for wheels) ---
recursive-include tests *.py

# --- Exclude junk ---
global-exclude __pycache__ *.py[cod] *.so

# --- Exclude editor / OS files ---
global-exclude .DS_Store *.swp *.swo